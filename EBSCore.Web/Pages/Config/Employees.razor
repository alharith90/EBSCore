@page "/Config/Employees"
@using Microsoft.JSInterop
@using Newtonsoft.Json
@using EBSCore.Web.Models
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Components.Forms
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IStringLocalizerFactory LocalizerFactory

<div class="modern-admin-page">
    <div class="modern-page-header">
        <h4 class="mb-0">@Localizer["Employees"]</h4>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-dark" @onclick="ApplySearch"><i class="fas fa-rotate"></i> @GLocalizer["Refresh"]</button>
            <button class="btn btn-success" @onclick="OpenAdd"><i class="fas fa-plus"></i> @GLocalizer["AddRecord"]</button>
        </div>
    </div>

    <div class="card modern-card">
        <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
            <EditForm EditContext="SearchFormContext" OnValidSubmit="ApplySearch" class="d-flex gap-2 w-100">
                <input class="form-control" placeholder="Search..." @bind="SearchQuery" />
                <button class="btn btn-outline-primary">@GLocalizer["Search"]</button>
            </EditForm>
        </div>

        <div class="card-body table-responsive">
            @if (EmployeeList?.Any() == true)
            {
                <table class="table table-hover modern-table align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>@Localizer["FullName"]</th>
                            <th>@Localizer["Email"]</th>
                            <th>@Localizer["Department"]</th>
                            <th>@Localizer["JobTitle"]</th>
                            <th>@Localizer["IsActive"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (e, idx) in EmployeeList.Select((x, i) => (x, i)))
                        {
                            <tr @onclick="() => OpenRead(e)">
                                <td>@((CurrentPage - 1) * PageSize + idx + 1)</td>
                                <td>@e.FullName</td>
                                <td>@e.Email</td>
                                <td>@e.Department</td>
                                <td>@e.JobTitle</td>
                                <td>
                                    <span class="badge @(e.IsActive == true ? "bg-success" : "bg-secondary")">@(e.IsActive == true ? "Active" : "Inactive")</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0">@GLocalizer["EmptyTable"]</p>
            }
        </div>
    </div>
</div>

@if (IsDrawerOpen)
{
    <div class="workspace-backdrop" @onclick="Close"></div>
    <div class="record-workspace-drawer">
        <div class="workspace-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">@Localizer[Current.EmployeeId.HasValue ? (IsReadMode ? "EmployeeDetails" : "EditEmployee") : "AddEmployee"]</h5>
                <small class="text-muted">@Localizer["ManageEmployeeDetails"]</small>
            </div>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="Close"><i class="fas fa-xmark"></i></button>
        </div>

        <EditForm EditContext="EditContext" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <div class="workspace-body">
                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <div class="alert alert-danger">@ErrorMessage</div>
                }

                <div class="workspace-section">
                    <h6>@Localizer["Identity"]</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["FullName"]</label>
                            <InputText class="form-control" @bind-Value="Current.FullName" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Email"]</label>
                            <InputText class="form-control" @bind-Value="Current.Email" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Phone"]</label>
                            <InputText class="form-control" @bind-Value="Current.Phone" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Position"]</label>
                            <InputText class="form-control" @bind-Value="Current.Position" disabled="@IsReadMode" />
                        </div>
                    </div>
                </div>

                <div class="workspace-section">
                    <h6>@Localizer["Organization"]</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["Department"]</label>
                            <InputText class="form-control" @bind-Value="Current.Department" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["JobTitle"]</label>
                            <InputText class="form-control" @bind-Value="Current.JobTitle" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["Location"]</label>
                            <InputText class="form-control" @bind-Value="Current.Location" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["OrganizationUnitId"]</label>
                            <InputNumber TValue="int?" class="form-control" @bind-Value="Current.OrganizationUnitId" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Localizer["SupervisorId"]</label>
                            <InputNumber TValue="int?" class="form-control" @bind-Value="Current.SupervisorId" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" @bind-Value="Current.IsActive" disabled="@IsReadMode" />
                                <label class="form-check-label">@Localizer["IsActive"]</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="workspace-footer d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary" @onclick="Close">@GLocalizer["Cancel"]</button>
                <div class="d-flex gap-2">
                    @if (IsReadMode)
                    {
                        <button type="button" class="btn btn-primary" @onclick="SwitchToEdit">@Localizer["EditEmployee"]</button>
                    }
                    else
                    {
                        @if (Current.EmployeeId.HasValue)
                        {
                            <button type="button" class="btn btn-outline-danger" @onclick="() => Remove(Current)">@GLocalizer["Delete"]</button>
                        }
                        <button class="btn btn-success" type="submit"><i class="fas fa-save"></i> @GLocalizer["Save"]</button>
                    }
                </div>
            </div>
        </EditForm>
    </div>
}

@code {
    private IStringLocalizer Localizer = default!;
    private IStringLocalizer GLocalizer = default!;

    private List<Employee> EmployeeList = new();
    private Employee Current = new();
    private bool IsDrawerOpen;
    private bool IsReadMode;
    private EditContext EditContext = default!;
    private EditContext SearchFormContext = new(new object());
    private string? ErrorMessage;

    private int CurrentPage = 1;
    private int PageSize = 10;
    private int TotalPages = 1;
    private string SearchQuery = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        Localizer = LocalizerFactory.Create(new Uri(Navigation.Uri).AbsolutePath, "");
        GLocalizer = LocalizerFactory.Create("Common", "");
        EditContext = new EditContext(Current);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var json = await Http.GetStringAsync($"/api/Employee/Get?PageNumber={CurrentPage}&PageSize={PageSize}&SearchQuery={SearchQuery}");
        var outer = Newtonsoft.Json.Linq.JToken.Parse(json);
        var inner = outer.Type == Newtonsoft.Json.Linq.JTokenType.String ? Newtonsoft.Json.Linq.JToken.Parse((string)outer) : outer;
        EmployeeList = inner["Data"].ToObject<List<Employee>>() ?? new();
        TotalPages = (int?)inner["PageCount"] ?? 1;
    }

    private async Task ApplySearch()
    {
        CurrentPage = 1;
        await LoadAsync();
    }

    private void OpenAdd()
    {
        Current = new Employee { IsActive = true };
        EditContext = new EditContext(Current);
        IsDrawerOpen = true;
        IsReadMode = false;
        ErrorMessage = null;
    }

    private void OpenRead(Employee e)
    {
        Current = CloneEmployee(e);
        EditContext = new EditContext(Current);
        IsDrawerOpen = true;
        IsReadMode = true;
        ErrorMessage = null;
    }

    private void SwitchToEdit() => IsReadMode = false;

    private void Close()
    {
        IsDrawerOpen = false;
        IsReadMode = false;
        ErrorMessage = null;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(Current.FullName))
        {
            ErrorMessage = Localizer["FullNameRequired"];
            return;
        }

        var res = await Http.PostAsJsonAsync("/api/Employee/Save", Current);
        if (res.IsSuccessStatusCode)
        {
            IsReadMode = true;
            await LoadAsync();
            await JS.InvokeVoidAsync("Toast.fire", new { icon = "success", title = Localizer["SavedSuccessfully"].Value });
        }
        else
        {
            ErrorMessage = Localizer["SaveFailed"];
        }
    }

    private async Task Remove(Employee e)
    {
        var res = await Http.DeleteAsync($"/api/Employee/Delete/{e.EmployeeId}");
        if (res.IsSuccessStatusCode)
        {
            Close();
            await LoadAsync();
            await JS.InvokeVoidAsync("Toast.fire", new { icon = "success", title = Localizer["DeletedSuccessfully"].Value });
        }
        else
        {
            ErrorMessage = Localizer["DeleteFailed"];
        }
    }

    private static Employee CloneEmployee(Employee e) => new()
    {
        EmployeeId = e.EmployeeId,
        FullName = e.FullName,
        Position = e.Position,
        Email = e.Email,
        Phone = e.Phone,
        OrganizationUnitId = e.OrganizationUnitId,
        SourceId = e.SourceId,
        SourceSystem = e.SourceSystem,
        JobTitle = e.JobTitle,
        JobFamily = e.JobFamily,
        SupervisorId = e.SupervisorId,
        EmploymentType = e.EmploymentType,
        Location = e.Location,
        Department = e.Department,
        IsActive = e.IsActive
    };
}
