@page "/Workflow/List"
@using EBSCore.Web.Models.Workflow
@using EBSCore.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@using Newtonsoft.Json
@using System.Net.Http.Json
@using EBSCore.Web.Pages.Controls

@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IStringLocalizerFactory LocalizerFactory
@inject PageTitleService PageTitleService

<div class="modern-admin-page">
    <div class="modern-page-header">
        <h4 class="mb-0">@Localizer["PageTitle"]</h4>
        <button type="button" class="btn btn-success" @onclick="StartCreate">
            <i class="fas fa-plus"></i>&nbsp; @GLocalizer["AddRecord"]
        </button>
    </div>

    <div class="card modern-card">
        <div class="card-header">
            <div class="d-flex align-items-center gap-2">
                <label class="form-label mb-0">@Localizer["UnitName"]</label>
                <UnitTreeSelector @bind-Value="SelectedUnitID" OnValueChanged="@(_ => ApplySearch())" />
                <button class="btn btn-outline-dark" @onclick="ApplySearch"><i class="fas fa-search"></i> @GLocalizer["Search"]</button>
            </div>
        </div>

        <div class="card-body table-responsive">
            @if (ListWorkflows.Any())
            {
                <table class="table table-hover modern-table align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>@Localizer["WorkflowName"]</th>
                            <th>@Localizer["WorkflowCode"]</th>
                            <th>@Localizer["Status"]</th>
                            <th>@Localizer["Priority"]</th>
                            <th>@Localizer["Frequency"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var idx = 0; }
                        @foreach (var w in ListWorkflows)
                        {
                            idx++;
                            <tr @onclick="() => OpenRead(w)">
                                <td>@idx</td>
                                <td>@w.WorkflowName</td>
                                <td>@w.WorkflowCode</td>
                                <td>@w.Status</td>
                                <td>@w.Priority</td>
                                <td>@w.Frequency</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0">@GLocalizer["EmptyTable"]</p>
            }
        </div>
    </div>
</div>

@if (IsDrawerOpen)
{
    <div class="workspace-backdrop" @onclick="CloseDrawer"></div>
    <div class="record-workspace-drawer">
        <div class="workspace-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">@DrawerTitle</h5>
                <small class="text-muted">@Localizer["WorkflowDrawerSubtitle"]</small>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="CloseDrawer"><i class="fas fa-xmark"></i></button>
        </div>

        <EditForm EditContext="EditContext" OnValidSubmit="SaveWorkflowAsync">
            <DataAnnotationsValidator />
            <div class="workspace-body">
                @if (ShowValidationMessage)
                {
                    <div class="alert alert-danger">@Localizer["PleaseFixValidation"]</div>
                }

                <div class="workspace-section">
                    <h6>@Localizer["BasicInfo"]</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["UnitName"]</label>
                            <UnitTreeSelector @bind-Value="CurrentWorkflow.UnitID" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["WorkflowName"]</label>
                            <InputText class="form-control" @bind-Value="CurrentWorkflow.WorkflowName" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["WorkflowCode"]</label>
                            <InputText class="form-control" @bind-Value="CurrentWorkflow.WorkflowCode" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Status"]</label>
                            <InputText class="form-control" @bind-Value="CurrentWorkflow.Status" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Priority"]</label>
                            <InputText class="form-control" @bind-Value="CurrentWorkflow.Priority" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Frequency"]</label>
                            <InputText class="form-control" @bind-Value="CurrentWorkflow.Frequency" disabled="@IsReadMode" />
                        </div>
                    </div>
                </div>

                <div class="workspace-section">
                    <h6>@Localizer["WorkflowDescription"]</h6>
                    <InputTextArea class="form-control" rows="4" @bind-Value="CurrentWorkflow.WorkflowDescription" disabled="@IsReadMode" />
                </div>
            </div>

            <div class="workspace-footer d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary" @onclick="CloseDrawer">@GLocalizer["Cancel"]</button>
                <div class="d-flex gap-2">
                    @if (IsReadMode)
                    {
                        <button type="button" class="btn btn-primary" @onclick="SwitchToEdit">@GLocalizer["Edit"]</button>
                    }
                    else
                    {
                        <button class="btn btn-success" type="submit"><i class="fas fa-save"></i> @GLocalizer["Save"]</button>
                    }
                </div>
            </div>
        </EditForm>
    </div>
}

@code {
    bool IsDrawerOpen;
    bool IsReadMode;
    bool ShowValidationMessage;

    List<WorkflowSummary> ListWorkflows = new();
    WorkflowDefinition CurrentWorkflow = new();
    string? SelectedUnitID;

    EditContext EditContext = default!;

    IStringLocalizer Localizer = default!;
    IStringLocalizer GLocalizer = default!;

    bool _firstRenderDone;

    string DrawerTitle => CurrentWorkflow.WorkflowID.HasValue
        ? (IsReadMode ? Localizer["ViewWorkflow"] : Localizer["ModalTitle"])
        : Localizer["ModalTitle"];

    protected override Task OnInitializedAsync()
    {
        EditContext = new EditContext(CurrentWorkflow);

        Localizer = LocalizerFactory.Create(new Uri(Navigation.Uri).AbsolutePath, "");
        GLocalizer = LocalizerFactory.Create("Common", "");
        PageTitleService.CurrentPageTitle = Localizer["PageTitle"];
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _firstRenderDone = true;
            await LoadWorkflowListAsync();
            StateHasChanged();
        }
    }

    private async Task ApplySearch() => await LoadWorkflowListAsync();

    private async Task LoadWorkflowListAsync()
    {
        try
        {
            string response = !string.IsNullOrEmpty(SelectedUnitID)
                ? await Http.GetStringAsync($"api/S7SWorkflow/GetByUnit?UnitID={SelectedUnitID}")
                : await Http.GetStringAsync("api/S7SWorkflow/Get");

            ListWorkflows = JsonConvert.DeserializeObject<List<WorkflowSummary>>(response) ?? new();
        }
        catch (Exception ex)
        {
            if (_firstRenderDone)
            {
                await JS.InvokeVoidAsync("Swal.fire", new { icon = "error", title = "Load Failed", text = ex.Message });
            }
        }

        StateHasChanged();
    }

    private void StartCreate()
    {
        CurrentWorkflow = new WorkflowDefinition { UnitID = SelectedUnitID };
        EditContext = new EditContext(CurrentWorkflow);
        ShowValidationMessage = false;
        IsReadMode = false;
        IsDrawerOpen = true;
    }

    private async Task OpenRead(WorkflowSummary workflow)
    {
        var item = await Http.GetFromJsonAsync<WorkflowDefinition>($"api/S7SWorkflow/GetByID?workflowID={workflow.WorkflowID}");
        CurrentWorkflow = item ?? new WorkflowDefinition();
        EditContext = new EditContext(CurrentWorkflow);
        IsReadMode = true;
        ShowValidationMessage = false;
        IsDrawerOpen = true;
    }

    private void SwitchToEdit() => IsReadMode = false;

    private void CloseDrawer()
    {
        IsDrawerOpen = false;
        IsReadMode = false;
        ShowValidationMessage = false;
    }

    private async Task SaveWorkflowAsync()
    {
        if (!EditContext.Validate())
        {
            ShowValidationMessage = true;
            return;
        }

        var response = await Http.PostAsJsonAsync("api/S7SWorkflow/Save", CurrentWorkflow);

        if (response.IsSuccessStatusCode)
        {
            IsReadMode = true;
            await LoadWorkflowListAsync();
            await JS.InvokeVoidAsync("Toast.fire", new { icon = "success", title = "Workflow saved successfully" });
        }
        else
        {
            await JS.InvokeVoidAsync("Swal.fire", new { icon = "error", title = "Error!", text = response.ReasonPhrase ?? "Save failed" });
        }
    }
}
