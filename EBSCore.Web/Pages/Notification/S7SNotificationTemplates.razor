@page "/Notification/Templates"
@using EBSCore.Web.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@using Newtonsoft.Json
@using EBSCore.Web.Services
@using System.Net.Http.Json

@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IStringLocalizerFactory LocalizerFactory
@inject PageTitleService PageTitleService

<div class="modern-admin-page">
    <div class="modern-page-header">
        <h4 class="mb-0">@Localizer["PageTitle"]</h4>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="LoadTemplates">
                <i class="fas fa-rotate"></i> @GLocalizer["Refresh"]
            </button>
            <button class="btn btn-success" @onclick="StartCreate">
                <i class="fas fa-plus"></i> @GLocalizer["AddRecord"]
            </button>
        </div>
    </div>

    <div class="card modern-card">
        <div class="card-header">
            <EditForm EditContext="SearchContext" OnValidSubmit="ApplySearch" class="d-flex gap-2 flex-wrap">
                <InputText class="form-control" @bind-Value="SearchQuery" placeholder="@GLocalizer["Search"]..." />
                <button class="btn btn-outline-dark" type="submit"><i class="fas fa-search"></i> @GLocalizer["Search"]</button>
            </EditForm>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-hover modern-table align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@Localizer["Name"]</th>
                        <th>@Localizer["TemplateKey"]</th>
                        <th>@Localizer["Channel"]</th>
                        <th>@Localizer["Subject"]</th>
                        <th>@Localizer["Active"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredTemplates.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">@GLocalizer["EmptyTable"]</td>
                        </tr>
                    }
                    else
                    {
                        var idx = 0;
                        foreach (var t in FilteredTemplates)
                        {
                            idx++;
                            <tr @onclick="() => OpenRead(t)">
                                <td>@idx</td>
                                <td>@t.Name</td>
                                <td>@t.TemplateKey</td>
                                <td>@t.ChannelID</td>
                                <td>@t.Subject</td>
                                <td>
                                    <span class="badge @(t.IsActive ? "bg-success" : "bg-secondary")">@(t.IsActive ? Localizer["Active"] : Localizer["Inactive"])</span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (IsDrawerOpen)
{
    <div class="workspace-backdrop" @onclick="CloseDrawer"></div>
    <div class="record-workspace-drawer">
        <div class="workspace-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">@DrawerTitle</h5>
                <small class="text-muted">@Localizer["EditTemplate"]</small>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="CloseDrawer"><i class="fas fa-xmark"></i></button>
        </div>

        <EditForm EditContext="EditContext" OnValidSubmit="SaveTemplateAsync">
            <DataAnnotationsValidator />
            <div class="workspace-body">
                @if (ShowValidationMessage)
                {
                    <div class="alert alert-danger">@Localizer["ValidationError"]</div>
                }

                <div class="workspace-section">
                    <h6>@Localizer["BasicInfo"]</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Name"]</label>
                            <InputText class="form-control" @bind-Value="CurrentTemplate.Name" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["TemplateKey"]</label>
                            <InputText class="form-control" @bind-Value="CurrentTemplate.TemplateKey" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Channel"]</label>
                            <InputNumber TValue="int" class="form-control" @bind-Value="CurrentTemplate.ChannelID" disabled="@IsReadMode" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Subject"]</label>
                            <InputText class="form-control" @bind-Value="CurrentTemplate.Subject" disabled="@IsReadMode" />
                        </div>
                    </div>
                </div>

                <div class="workspace-section">
                    <h6>@Localizer["Body"]</h6>
                    <InputTextArea class="form-control" rows="8" @bind-Value="CurrentTemplate.Body" disabled="@IsReadMode" />
                </div>

                <div class="workspace-section">
                    <h6>@Localizer["Options"]</h6>
                    <div class="d-flex gap-4">
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" @bind-Value="CurrentTemplate.UseDesign" disabled="@IsReadMode" />
                            <label class="form-check-label">@Localizer["UseDesign"]</label>
                        </div>
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" @bind-Value="CurrentTemplate.IsActive" disabled="@IsReadMode" />
                            <label class="form-check-label">@Localizer["Active"]</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="workspace-footer d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary" @onclick="CloseDrawer">@GLocalizer["Cancel"]</button>
                <div class="d-flex gap-2">
                    @if (IsReadMode)
                    {
                        <button type="button" class="btn btn-primary" @onclick="SwitchToEdit">@GLocalizer["Edit"]</button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> @GLocalizer["Save"]</button>
                    }
                </div>
            </div>
        </EditForm>
    </div>
}

@code {
    private bool IsDrawerOpen;
    private bool IsReadMode;
    private bool ShowValidationMessage;
    private string SearchQuery = string.Empty;

    private List<S7SNotificationTemplate> Templates = new();
    private List<S7SNotificationTemplate> FilteredTemplates = new();
    private S7SNotificationTemplate CurrentTemplate = new();

    private EditContext EditContext = default!;
    private EditContext SearchContext = new(new object());

    private IStringLocalizer Localizer = default!;
    private IStringLocalizer GLocalizer = default!;

    private string DrawerTitle => CurrentTemplate.NotificationTemplateID.HasValue
        ? (IsReadMode ? Localizer["ViewTemplate"] : Localizer["EditTemplate"])
        : GLocalizer["AddRecord"];

    protected override async Task OnInitializedAsync()
    {
        Localizer = LocalizerFactory.Create(new Uri(Navigation.Uri).AbsolutePath, "");
        GLocalizer = LocalizerFactory.Create("Common", "");
        PageTitleService.CurrentPageTitle = Localizer["PageTitle"];

        EditContext = new EditContext(CurrentTemplate);
        await LoadTemplates();
    }

    private async Task LoadTemplates()
    {
        var json = await Http.GetStringAsync("api/S7SNotification/RtvTemplates");
        Templates = JsonConvert.DeserializeObject<List<S7SNotificationTemplate>>(json) ?? new();
        ApplySearch();
    }

    private void ApplySearch()
    {
        var query = SearchQuery?.Trim();
        if (string.IsNullOrWhiteSpace(query))
        {
            FilteredTemplates = Templates.OrderBy(t => t.Name).ToList();
            return;
        }

        FilteredTemplates = Templates
            .Where(t => (t.Name ?? string.Empty).Contains(query, StringComparison.OrdinalIgnoreCase)
                     || (t.TemplateKey ?? string.Empty).Contains(query, StringComparison.OrdinalIgnoreCase)
                     || (t.Subject ?? string.Empty).Contains(query, StringComparison.OrdinalIgnoreCase))
            .OrderBy(t => t.Name)
            .ToList();
    }

    private void StartCreate()
    {
        CurrentTemplate = new S7SNotificationTemplate { IsActive = true, UseDesign = true, ChannelID = 1 };
        EditContext = new EditContext(CurrentTemplate);
        IsReadMode = false;
        IsDrawerOpen = true;
        ShowValidationMessage = false;
    }

    private void OpenRead(S7SNotificationTemplate t)
    {
        CurrentTemplate = CloneTemplate(t);
        EditContext = new EditContext(CurrentTemplate);
        IsReadMode = true;
        IsDrawerOpen = true;
        ShowValidationMessage = false;
    }

    private void SwitchToEdit() => IsReadMode = false;

    private void CloseDrawer()
    {
        IsDrawerOpen = false;
        IsReadMode = false;
        ShowValidationMessage = false;
    }

    private async Task SaveTemplateAsync()
    {
        if (!EditContext.Validate())
        {
            ShowValidationMessage = true;
            return;
        }

        var response = await Http.PostAsJsonAsync("api/S7SNotification/SaveTemplate", CurrentTemplate);
        if (!response.IsSuccessStatusCode)
        {
            ShowValidationMessage = true;
            return;
        }

        await LoadTemplates();
        IsReadMode = true;
        await JS.InvokeVoidAsync("Toast.fire", new { icon = "success", title = Localizer["SavedSuccessfully"].Value });
    }

    private static S7SNotificationTemplate CloneTemplate(S7SNotificationTemplate t)
        => new()
        {
            NotificationTemplateID = t.NotificationTemplateID,
            Name = t.Name,
            TemplateKey = t.TemplateKey,
            ChannelID = t.ChannelID,
            Subject = t.Subject,
            Body = t.Body,
            UseDesign = t.UseDesign,
            IsActive = t.IsActive
        };
}
